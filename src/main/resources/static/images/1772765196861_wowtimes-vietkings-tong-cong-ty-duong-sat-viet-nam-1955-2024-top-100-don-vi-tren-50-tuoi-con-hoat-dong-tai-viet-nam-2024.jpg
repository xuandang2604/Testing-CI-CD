    <script type="text/javascript">
        $(window).load(function() {
            $('.ft-partner').show();
            var count = $('#owl-partner .item img').length;
            var owl = $("#owl-partner");

            if (count > 1)
            {
                owl.owlCarousel({

                    margin: 10,
                    autoplay: 5000,
                    smartSpeed: 450,
                    stopOnHover: true,
                    loop: true,
                    dots: false,
                    dotsEach: 1,
                    nav: false,
                    lazyLoad : true,
                    navClass: ['owl-prev fa fa-angle-left', 'owl-next fa fa-angle-right'],
                    responsive: {
                        0: {items: 2},
                        320: {items: 2},
                        460: {items: 4},
                        768: {items: 6},
                        980: {items: 6},
                        1200: {items: 8}
                    }
                });

            }
            else
            {
                owl.show();

            }

           
        });
    </script>

